# Copy to .env.local and fill values as needed
# NEXT_PUBLIC_* variables are exposed to the browser

NEXT_PUBLIC_APP_NAME=Sojourns
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk Auth (create at https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional custom routes (uncomment to customize)
# CLERK_SIGN_IN_URL=/sign-in
# CLERK_SIGN_UP_URL=/sign-up

# Resend email (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=Sojourns <noreply@example.com>

# Cloudflare R2 object storage
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for the bucket (enable public access in Cloudflare dashboard → R2 → bucket → Settings)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
